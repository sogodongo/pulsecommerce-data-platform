# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# ── MSK (Kafka) ───────────────────────────────────────────────────────────────
MSK_BROKERS=b-1.pulsecommerce.abc123.kafka.us-east-1.amazonaws.com:9094,b-2.pulsecommerce.abc123.kafka.us-east-1.amazonaws.com:9094
SCHEMA_REGISTRY_URL=http://schema-registry.internal:8081

# ── S3 Lakehouse ──────────────────────────────────────────────────────────────
LAKEHOUSE_BUCKET=pulsecommerce-lakehouse-123456789012
GLUE_SCRIPTS_BUCKET=pulsecommerce-glue-scripts-123456789012
FLINK_CHECKPOINTS_BUCKET=pulsecommerce-flink-checkpoints-123456789012

# ── Glue ──────────────────────────────────────────────────────────────────────
GLUE_DATABASE_BRONZE=bronze
GLUE_DATABASE_SILVER=silver
GLUE_DATABASE_GOLD=gold

# ── Redshift Serverless ───────────────────────────────────────────────────────
REDSHIFT_WORKGROUP=pulsecommerce-analytics
REDSHIFT_DATABASE=pulsecommerce

# ── SageMaker ─────────────────────────────────────────────────────────────────
SAGEMAKER_ROLE_ARN=arn:aws:iam::123456789012:role/pulsecommerce-sagemaker-role
CHURN_ENDPOINT_NAME=pulsecommerce-churn-endpoint-v1
FEATURE_GROUP_NAME=user-behavioral-features

# ── PostgreSQL CDC (source) ───────────────────────────────────────────────────
RDS_HOST=orders-db.cluster.rds.amazonaws.com
RDS_PORT=5432
RDS_DBNAME=pulsecommerce
RDS_USERNAME=debezium_user
RDS_PASSWORD=CHANGE_ME

# ── PII / Security ────────────────────────────────────────────────────────────
PII_SALT=CHANGE_ME_USE_SECRETS_MANAGER_IN_PROD

# ── Ad Attribution APIs ───────────────────────────────────────────────────────
FACEBOOK_ACCESS_TOKEN=CHANGE_ME
FACEBOOK_AD_ACCOUNT_ID=act_CHANGE_ME
GOOGLE_ADS_DEVELOPER_TOKEN=CHANGE_ME
GOOGLE_ADS_CUSTOMER_ID=CHANGE_ME

# ── Airflow (MWAA) ────────────────────────────────────────────────────────────
MWAA_ENV_NAME=pulsecommerce-airflow
MWAA_S3_BUCKET=pulsecommerce-mwaa-123456789012

# ── Great Expectations ────────────────────────────────────────────────────────
GX_CLOUD_ORGANIZATION_ID=CHANGE_ME
GX_CLOUD_ACCESS_TOKEN=CHANGE_ME

# ── FastAPI ───────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080
LOG_LEVEL=info
